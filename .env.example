# Database - Render PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host:5432/armvet_db

# Authentication - Admin credentials
# Username for dashboard login
ADMIN_USERNAME=admin
# Plain-text password — only used by `npm run db:seed` to hash and store in the database
ADMIN_PASSWORD=your-password-here

# JWT secret - use a long random string
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-jwt-secret-here

# CORS - optional overrides
PUBLIC_SITE_URL=https://armvet.onrender.com
DASHBOARD_URL=https://armvet-dashboard.onrender.com

# Environment
NODE_ENV=production
PORT=3001
